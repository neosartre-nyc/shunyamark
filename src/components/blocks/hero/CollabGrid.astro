---
// Media Grid
// ------------
// Description: A hero section with a title, a subtitle, a description and a media grid
// Properties:
// - title: The title of the hero section
// - text: The subtitle of the hero section
// - description: The description of the hero section

// Components
// - Layout
// - Blocks
import BasicHeroCTA from './BasicHeroCTA.astro'
// - UI

// Content
// - Props
type Props = {
	title?: string
	text?: string
	description?: string
}
const { title = '', text = '', description = '' } = Astro.props
---

<BasicHeroCTA title={title} text={text} classes="pb-12!" />
