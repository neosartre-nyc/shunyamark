---
// cites List
// ------------
// Description: A cites section with a title, a subtitle, a description and a grid of cites
// Properties:
// - title: The title of the cites section
// - text: The subtitle of the cites section

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - Blocks
import TitleSection from '../basic/TitleSection.astro'
// - UI
import BasicCard from '../../ui/cards/Card.astro'

// Content
// - Data
import citesData from '../../../data/json-files/citesData.json'
// - Props
const { title = '', text = '' } = Astro.props
---
<TitleSection title={title} text={text} classes="pb-0!" />
<Section>
	{
		citesData.map((cite) => (
			<Row classes="mb-12 ">
				<Col start="3" span="8" classes="h-full w-full grow">
					<BasicCard 
						decoration="all" style="transparent"
						title={cite.cite}
					>
						<div class="w-full space-y-4">
							{cite.anno.map((anno: string) => (
								<p class="relative z-10 text-lg w-full break-words">{anno}</p>
							))}
						</div>
					</BasicCard>
				</Col>
			</Row>
		))
	}
</Section>

